#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
skill_dir="$(dirname "$script_dir")"
cli="$skill_dir/scripts/ytdl"

if [ ! -f "$cli" ]; then
  echo "Error: $cli not found" >&2
  exit 1
fi

target_dir="$HOME/.local/bin"

# Ensure ~/.local/bin is on PATH (mirrors the gsearch/xsearch setup).
if ! echo ":$PATH:" | grep -q ":$target_dir:"; then
  mkdir -p "$target_dir"
  profile=""
  for f in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    if [ -f "$f" ]; then profile="$f"; break; fi
  done
  if [ -n "$profile" ] && ! grep -q '\.local/bin' "$profile"; then
    printf '\nexport PATH="$HOME/.local/bin:$PATH"\n' >> "$profile"
    echo "Added $target_dir to PATH in $profile"
  fi
  export PATH="$target_dir:$PATH"
fi

mkdir -p "$target_dir"
ln -sf "$cli" "$target_dir/ytdl"
echo "Linked: $target_dir/ytdl"

# ytdl runs on bun (the CLI is a bun-shebang script). Bun is already required by
# the cdp skill's REPL, but ensure it's discoverable for a standalone install.
if ! command -v bun >/dev/null 2>&1; then
  if [ -x "$HOME/.bun/bin/bun" ]; then
    ln -sf "$HOME/.bun/bin/bun" "$target_dir/bun"
    echo "Linked: $target_dir/bun"
  else
    echo "Warning: bun not found. The cdp skill installs it (run its setup), or:" >&2
    echo "  curl -fsSL https://bun.sh/install | bash" >&2
  fi
fi

# ytdl can optionally read cookies/STS from a live YouTube tab via browser-harness-js.
# Symlink it if the cdp skill is installed and it isn't already on PATH.
if ! command -v browser-harness-js >/dev/null 2>&1; then
  bhjs="$skill_dir/../cdp/sdk/browser-harness-js"
  if [ -f "$bhjs" ]; then
    ln -sf "$bhjs" "$target_dir/browser-harness-js"
    echo "Linked: $target_dir/browser-harness-js (optional; for gated content)"
  fi
fi

# HD (720p+) needs ffmpeg for the video+audio mux.
if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "Warning: ffmpeg not found. Required for 720p+ (HD) downloads; 360p muxed works without it." >&2
  echo "  brew install ffmpeg   (or your platform's equivalent)" >&2
fi
