#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "$0")" && pwd)"
skill_dir="$(dirname "$script_dir")"
cli="$skill_dir/scripts/ttdl"

if [ ! -f "$cli" ]; then
  echo "Error: $cli not found" >&2
  exit 1
fi

target_dir="$HOME/.local/bin"

# Ensure ~/.local/bin is on PATH (mirrors the gsearch/xsearch/ytdl setup).
if ! echo ":$PATH:" | grep -q ":$target_dir:"; then
  mkdir -p "$target_dir"
  profile=""
  for f in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.profile"; do
    if [ -f "$f" ]; then profile="$f"; break; fi
  done
  if [ -n "$profile" ] && ! grep -q '\.local/bin' "$profile"; then
    printf '\nexport PATH="$HOME/.local/bin:$PATH"\n' >> "$profile"
    echo "Added $target_dir to PATH in $profile"
  fi
  export PATH="$target_dir:$PATH"
fi

mkdir -p "$target_dir"
ln -sf "$cli" "$target_dir/ttdl"
echo "Linked: $target_dir/ttdl"

# ttdl is a browser-harness-js heredoc (no bun program). Symlink
# browser-harness-js if the cdp skill is installed and it isn't on PATH.
if ! command -v browser-harness-js >/dev/null 2>&1; then
  bhjs="$skill_dir/../cdp/sdk/browser-harness-js"
  if [ -f "$bhjs" ]; then
    ln -sf "$bhjs" "$target_dir/browser-harness-js"
    echo "Linked: $target_dir/browser-harness-js (required)"
  else
    echo "Warning: browser-harness-js not found. Install the cdp skill, or run its setup." >&2
  fi
fi

# ttdl ALWAYS needs ffmpeg: TikTok serves audio+video as separate SourceBuffers
# (mux), trims the edit-list tail to the played duration, and faststarts the
# output. Unlike ytdl (where ffmpeg is only needed for HD), it's a hard req.
if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "Warning: ffmpeg not found. Required to mux audio+video, trim, and faststart." >&2
  echo "  brew install ffmpeg   (or your platform's equivalent)" >&2
fi
