#!/usr/bin/env bash
# browser-harness-js — eval JS in the persistent CDP REPL. Auto-starts the REPL on first use.
#
# Usage:
#   browser-harness-js 'await session.connect()'
#   browser-harness-js 'await session.Page.navigate({url:"https://example.com"})'
#   browser-harness-js <<'EOF'
#     const t = await listPageTargets();
#     globalThis.tid = t[0].targetId;
#     await session.use(globalThis.tid);
#     globalThis.tid
#   EOF
#
#   browser-harness-js --status   # is the REPL running? prints health JSON
#   browser-harness-js --stop     # gracefully shut it down
#   browser-harness-js --logs     # tail the REPL log
#   browser-harness-js --restart  # stop + start fresh (drops session state)
#   browser-harness-js --start    # explicit start (no-op if already running)
#   browser-harness-js --version  # print the SDK version (from the on-disk files)
#   browser-harness-js recordings [--latest|enable|disable]
#   browser-harness-js video init|review|export <recording> [options]
#   browser-harness-js --no-auto-allow 'await session.connect()'  # macOS: opt out of auto-dismissing Dia's "Allow debugging connection?" prompt (on by default)

set -euo pipefail

PORT="${CDP_REPL_PORT:-9876}"
HOST="127.0.0.1"
URL="http://$HOST:$PORT"

# Resolve repl.ts alongside this script, following symlinks (e.g. /usr/local/bin/browser-harness-js → <skill-dir>/sdk/browser-harness-js).
SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
  [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
SDK_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
REPL="$SDK_DIR/repl.ts"

LOG="${CDP_REPL_LOG:-/tmp/browser-harness-js.log}"

# The on-disk SDK version (read fresh each call). The daemon serves its own
# boot-cached copy in /health, so a mismatch reveals a stale running daemon.
sdk_version() {
  sed -n 's/^[[:space:]]*"version":[[:space:]]*"\([^"]*\)".*/\1/p' "$SDK_DIR/package.json" 2>/dev/null | head -1
}

# The REPL server runs on Node.js (no runtime auto-install — Node is expected
# to be on PATH already). Fail fast with a clear message if it's missing.
ensure_node() {
  if command -v node >/dev/null 2>&1; then return 0; fi
  echo "browser-harness-js: node not found on PATH. Install Node.js (https://nodejs.org) and retry." >&2
  return 1
}

is_up() {
  curl -fsS --max-time 1 "$URL/health" >/dev/null 2>&1
}

start_repl() {
  is_up && return 0
  ensure_node || return 1
  CDP_REPL_PORT="$PORT" nohup node "$REPL" >"$LOG" 2>&1 &
  for _ in $(seq 1 100); do
    sleep 0.1
    is_up && return 0
  done
  echo "browser-harness-js: REPL failed to start on $URL (see $LOG)" >&2
  return 1
}

post_eval() {
  # Capture body + status separately. Body goes to stdout (only if non-empty)
  # on 200; otherwise to stderr with non-zero exit.
  local out status body
  out=$(curl -sS -w '\n___STATUS___%{http_code}' --data-binary "$1" "$URL/eval")
  status="${out##*___STATUS___}"
  body="${out%$'\n'___STATUS___*}"
  if [ "$status" = "200" ]; then
    [ -n "$body" ] && printf '%s\n' "$body"
    return 0
  else
    [ -n "$body" ] && printf '%s\n' "$body" >&2
    return 1
  fi
}

# Extract --no-auto-allow (may precede the code arg, e.g. --no-auto-allow 'await session.connect()')
NO_AUTO_ALLOW=0
POS=()
for a in "$@"; do
  case "$a" in
    --no-auto-allow) NO_AUTO_ALLOW=1 ;;
    *) POS+=("$a") ;;
  esac
done
set -- "${POS[@]+"${POS[@]}"}"

case "${1:-}" in
  --status)
    if is_up; then
      curl -sS "$URL/health"; echo
    else
      echo '{"ok":false,"error":"down"}'
      exit 1
    fi
    ;;
  --version|-V)
    v="$(sdk_version)"; printf '%s\n' "${v:-unknown}"
    ;;
  --start)
    start_repl
    curl -sS "$URL/health"; echo
    ;;
  --stop)
    if is_up; then
      curl -s -X POST "$URL/quit" >/dev/null || true
      echo '{"ok":true,"stopped":true}'
    else
      echo '{"ok":true,"stopped":false,"note":"already down"}'
    fi
    ;;
  --restart)
    is_up && curl -s -X POST "$URL/quit" >/dev/null 2>&1 || true
    sleep 0.2
    start_repl
    curl -sS "$URL/health"; echo
    ;;
  --logs)
    exec tail -f "$LOG"
    ;;
  recordings)
    ensure_node || exit 1
    exec node "$SDK_DIR/recording.ts" "${@:2}"
    ;;
  video)
    ensure_node || exit 1
    exec node "$SDK_DIR/video.ts" "${@:2}"
    ;;
  --help|-h)
    sed -n '2,/^set -euo/p' "$0" | sed 's/^#//; s/^ //; /^set -euo/d'
    ;;
  "")
    start_repl
    if [ "$NO_AUTO_ALLOW" = "1" ]; then
      post_eval 'session.autoAllow = false' >/dev/null 2>&1 || true
    fi
    code="$(cat)"
    post_eval "$code"
    ;;
  *)
    start_repl
    if [ "$NO_AUTO_ALLOW" = "1" ]; then
      post_eval 'session.autoAllow = false' >/dev/null 2>&1 || true
    fi
    post_eval "$1"
    ;;
esac
