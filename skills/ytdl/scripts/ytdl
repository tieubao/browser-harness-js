#!/usr/bin/env bash
set -euo pipefail

# ytdl — browser-native YouTube downloader.
#
#   ytdl <url|id>                          # best quality → ~/Downloads
#   ytdl youtube.com/shorts/<id>           # Shorts (→ watch?v=)
#   ytdl <url|id> -q 360p                  # 360p
#   ytdl <url|id> -q 1080p                 # 1080p (ffmpeg mux)
#   ytdl <url|id> -q audio                 # audio only
#   ytdl <url|id> --info                   # title / duration / qualities, no download
#   ytdl <url|id> -o Name -d ~/Videos      # custom name / dir
#   ytdl <url|id> -v                       # stats to stderr
#
# 100% browser-harness-js native: the browser plays the video (auth, poToken,
# n-solving, SABR demux all done by the page), and ytdl records what the player
# feeds MediaSource via a SourceBuffer.appendBuffer hook. No yt-dlp, no client
# impersonation, no n-signature solver. ffmpeg is a muxer only (HD video+audio).

# Auto-fix: if browser-harness-js isn't on PATH, try to find and symlink it.
if ! command -v browser-harness-js >/dev/null 2>&1; then
  _bhjs="$(cd "$(dirname "$0")/.." && pwd)/../cdp/sdk/browser-harness-js"
  if [ -f "$_bhjs" ]; then
    _bindir="$HOME/.local/bin"
    mkdir -p "$_bindir"
    ln -sf "$_bhjs" "$_bindir/browser-harness-js"
    export PATH="$_bindir:$PATH"
  else
    echo "ytdl: browser-harness-js not found. Run: bash <skill-dir>/scripts/setup" >&2
    exit 1
  fi
fi

usage() {
  cat >&2 <<'USAGE'
Usage: ytdl <url|id> [options]
  -q, --quality <q>   360p|480p|720p|1080p|1440p|2160p|best|audio  (default: best)
  -o, --out <name>    output filename (without extension)
  -d, --dir <path>    output directory (default: ~/Downloads)
  --info              print title / duration / available qualities, no download
  -v, --verbose        print capture stats to stderr
  -h, --help           this message
USAGE
  exit 1
}

[ $# -lt 1 ] && usage

quality="best"
out=""
dir="${HOME}/Downloads"
info_only=false
verbose=false

while [ $# -gt 0 ]; do
  case "$1" in
    -q|--quality) quality="${2:?missing quality}"; shift 2;;
    -o|--out) out="${2:?missing out}"; shift 2;;
    -d|--dir) dir="${2:?missing dir}"; shift 2;;
    --info) info_only=true; shift;;
    -v|--verbose) verbose=true; shift;;
    -h|--help) usage;;
    -*) echo "ytdl: unknown option '$1'" >&2; usage;;
    *) [ -n "${input:-}" ] && { echo "ytdl: unexpected argument '$1'" >&2; usage; }; input="$1"; shift;;
  esac
done

input="${input:?Usage: ytdl <url|id> [options]}"

# Normalize to an 11-char video ID, then to a watch URL.
extract_id() {
  local u="$1"
  if [[ "$u" =~ ^[A-Za-z0-9_-]{11}$ ]]; then echo "$u"; return 0; fi
  local id
  id=$(printf '%s' "$u" | sed -nE 's/.*[?&]v=([A-Za-z0-9_-]{11}).*/\1/p' | head -1)
  [ -n "$id" ] && { echo "$id"; return 0; }
  id=$(printf '%s' "$u" | sed -nE 's#.*youtu\.be/([A-Za-z0-9_-]{11}).*#\1#p' | head -1)
  [ -n "$id" ] && { echo "$id"; return 0; }
  id=$(printf '%s' "$u" | sed -nE 's#.*youtube\.com/embed/([A-Za-z0-9_-]{11}).*#\1#p' | head -1)
  [ -n "$id" ] && { echo "$id"; return 0; }
  # YouTube Shorts: youtube.com/shorts/<id>[/...]?... — a Short is just a video,
  # so normalize to watch?v=<id> below and capture it in the regular watch player.
  # The Shorts page is a different UI shell around the same #movie_player; the
  # watch URL is the path ytdl's selectors / autonav / quality logic targets.
  id=$(printf '%s' "$u" | sed -nE 's#.*youtube\.com/shorts/([A-Za-z0-9_-]{11}).*#\1#p' | head -1)
  [ -n "$id" ] && { echo "$id"; return 0; }
  return 1
}
vid=$(extract_id "$input") || { echo "ytdl: could not parse a video ID from '$input'" >&2; exit 1; }
watch_url="https://www.youtube.com/watch?v=${vid}"

# Map -q to a YouTube player quality label and what to keep.
case "$quality" in
  360p)  ytq="medium";  keep="both";;
  480p)  ytq="large";   keep="both";;
  720p)  ytq="hd720";   keep="both";;
  1080p) ytq="hd1080";  keep="both";;
  1440p) ytq="hd1440";  keep="both";;
  2160p|4k) ytq="hd2160"; keep="both";;
  best|max) ytq="max";  keep="both";;
  audio) ytq="tiny";  keep="audio";;
  *) echo "ytdl: unknown quality '$quality' (360p|480p|720p|1080p|1440p|2160p|best|audio)" >&2; exit 1;;
esac

# Verbose as a JS boolean for the heredoc.
js_verbose="false"; $verbose && js_verbose="true"
js_info="false"; $info_only && js_info="true"

tmpdir=$(mktemp -d 2>/dev/null || mktemp -d -t ytdl)
trap 'rm -rf "$tmpdir"' EXIT

# Escape the watch URL for a JS single-quoted string inside an unquoted heredoc:
# \ → \\, $ → \$, ` → \`, ' → \'
js_url=$(printf '%s' "$watch_url" | sed -e 's/\\/\\\\/g' -e 's/\$/\\$/g' -e 's/`/\\`/g' -e "s/'/\\\\'/g")

raw=$(browser-harness-js <<EOF
const fs = await import('node:fs')
const WATCH_URL = '${js_url}'
const YTQ = '${ytq}'
const KEEP = '${keep}'
const TMPDIR = '${tmpdir}'
const VERBOSE = ${js_verbose}
const INFO_ONLY = ${js_info}

const _stats = []
function vlog(s){ _stats.push(s) }

if (!session.isConnected()) {
  try { await session.connect() } catch (e) { throw new Error('Cannot connect to browser: ' + e.message) }
}

const t = await session.Target.createTarget({ url: 'about:blank' })  // foreground — autoplay needs it
const { sessionId } = await session.Target.attachToTarget({ targetId: t.targetId, flatten: true })

try {
  await cdp(sessionId, 'Page.enable', {})
  await cdp(sessionId, 'Page.setLifecycleEventsEnabled', { enabled: true })

  // Inject BEFORE navigate: hook MediaSource.addSourceBuffer + each SourceBuffer's
  // appendBuffer to record the demuxed ISO-BMFF bytes the player feeds MSE.
  // appendBuffer is a non-writable native property on the prototype, so we define
  // an OWN property on each SourceBuffer instance (shadows the prototype method).
  await cdp(sessionId, 'Page.addScriptToEvaluateOnNewDocument', {
    source: [
      '(() => {',
      '  if (window.__ytdlHooked) return;',
      '  window.__ytdlHooked = true;',
      '  window.__cap = { buffers: [] };',
      '  window.__capDone = false;',
      '  const bySb = new WeakMap();',
      '  const origAddSB = MediaSource.prototype.addSourceBuffer;',
      '  Object.defineProperty(MediaSource.prototype, "addSourceBuffer", {',
      '    configurable: true, writable: true,',
      '    value: function(mime) {',
      '      const sb = origAddSB.call(this, mime);',
      '      const entry = { mime: mime, chunks: [], bytes: 0, count: 0,',
      '        kind: mime.startsWith("video") ? "video" : mime.startsWith("audio") ? "audio" : "other" };',
      '      window.__cap.buffers.push(entry);',
      '      bySb.set(sb, entry);',
      '      const origApp = sb.appendBuffer.bind(sb);',
      '      Object.defineProperty(sb, "appendBuffer", {',
      '        configurable: true, writable: true,',
      '        value: function(data) {',
      '          if (window.__capDone) return origApp(data);',
      '          const u8 = data instanceof ArrayBuffer ? new Uint8Array(data)',
      '            : new Uint8Array(data.buffer, data.byteOffset, data.byteLength);',
      '          entry.chunks.push(u8.slice()); entry.bytes += u8.length; entry.count++;',
      '          return origApp(data);',
      '        }',
      '      });',
      '      return sb;',
      '    }',
      '  });',
      '  // page-side helpers used by the drain + final-tail pull. __drainNew',
      '  // returns chunks appended since the last call, base64-encoded, for the',
      '  // during-playback drain so bytes are on disk by latch-time. __pullBuffer',
      '  // is the absolute-offset slice pull used for the final tail after the hook',
      '  // is frozen. Both cap each CDP response at a SMALL slice: a single 4MB',
      '  // returnByValue frame closes the debug socket on some browsers (proven),',
      '  // so each response stays well under that. __drainNew never emits more than',
      '  // maxBytes even if a single appended fmp4 segment exceeds it — it slices',
      '  // a too-big chunk across drains (a 1440p segment is often 1-4MB), so the',
      '  // old force-one-whole-chunk-through path that dropped the socket is gone.',,
      '  window.__capInfo = function() {',
      '    return window.__cap.buffers.map((b,i) => ({ i: i, kind: b.kind, mime: b.mime, bytes: b.bytes, count: b.count }));',
      '  };',
      '  window.__pullBuffer = function(i, offset, len) {',
      '    const b = window.__cap.buffers[i];',
      '    if (!b._all) {',
      '      b._all = new Uint8Array(b.bytes);',
      '      let o = 0; for (const c of b.chunks) { b._all.set(c, o); o += c.length; }',
      '    }',
      '    const end = Math.min(offset + len, b._all.length);',
      '    const slice = b._all.subarray(offset, end);',
      '    // 49998 is divisible by 3 -> no interior base64 padding; fromCharCode.apply',
      '    // stays under the call-stack arg limit.',
      '    let b64 = "";',
      '    for (let i2 = 0; i2 < slice.length; i2 += 49998) {',
      '      const e2 = Math.min(i2 + 49998, slice.length);',
      '      b64 += btoa(String.fromCharCode.apply(null, slice.subarray(i2, e2)));',
      '    }',
      '    return b64;',
      '  };',
      '  // Incremental drain: return up to maxBytes of the chunks appended since',
      '  // the last call, advancing a per-buffer (_chunkIdx,_chunkOff) cursor.',
      '  // A chunk larger than maxBytes is sliced: this call returns its head and',
      '  // leaves _chunkOff pointing into it for the next call. NEVER emits more than',
      '  // maxBytes — the crash that dropped the socket was the old force-one-',
      '  // whole-chunk-through path (emitting a multi-MB frame for a big segment).',
      '  window.__drainNew = function(i, maxBytes) {',
      '    maxBytes = maxBytes || 262143;',
      '    const b = window.__cap.buffers[i];',
      '    if (!b) return { done: true, b64: "" };',
      '    if (b._chunkIdx === undefined) { b._chunkIdx = 0; b._chunkOff = 0; }',
      '    let remaining = maxBytes;',
      '    const parts = [];',
      '    while (remaining > 0 && b._chunkIdx < b.chunks.length) {',
      '      const c = b.chunks[b._chunkIdx];',
      '      const take = Math.min(remaining, c.length - b._chunkOff);',
      '      parts.push(b._chunkOff === 0 && take === c.length ? c : c.subarray(b._chunkOff, b._chunkOff + take));',
      '      b._chunkOff += take; remaining -= take;',
      '      if (b._chunkOff >= c.length) { b._chunkIdx++; b._chunkOff = 0; }',
      '    }',
      '    const done = b._chunkIdx >= b.chunks.length;',
      '    if (parts.length === 0) return { done: true, b64: "" };',
      '    let total = 0; for (const p of parts) total += p.length;',
      '    const u8 = new Uint8Array(total);',
      '    let o = 0; for (const p of parts) { u8.set(p, o); o += p.length; }',
      '    let b64 = "";',
      '    for (let k = 0; k < u8.length; k += 49998) {',
      '      const e = Math.min(k + 49998, u8.length);',
      '      b64 += btoa(String.fromCharCode.apply(null, u8.subarray(k, e)));',
      '    }',
      '    return { done: done, b64: b64, bytes: total };',
      '  };',
      '})();'
    ].join('\\n')
  })

  const ready = session.waitFor({ method: 'Page.lifecycleEvent', sessionId, predicate: (p) => p.name === 'networkIdle', timeoutMs: 30_000 })
  await cdp(sessionId, 'Page.navigate', { url: WATCH_URL })
  await ready
  vlog('navigated')

  // Wait for the player + <video> element (up to 60s — the player can be slow
  // to boot on a cold tab, and we must not require duration>0 yet: metadata
  // loads only once the player starts fetching, which may need the play nudge).
  let playerReady = false
  let diag = ''
  for (let i = 0; i < 120; i++) {
    const r = await cdp(sessionId, 'Runtime.evaluate', {
      expression: '(() => { const v = document.querySelector("video"); const p = document.querySelector("#movie_player"); const body = document.body ? document.body.innerText.slice(0,200) : ""; const bot = /unusual traffic|Our systems have detected|Are you a robot|not a robot/i.test(body); return JSON.stringify({ v: !!v, p: !!p, bot, title: document.title || "" }); })()',
      returnByValue: true
    })
    const s = JSON.parse(r.result.value)
    if (s.bot) throw new Error('YouTube is showing an "unusual traffic / are you a robot" interstitial — back off and retry later (or open the URL manually once in the browser to clear it).')
    if (s.v && s.p) { playerReady = true; break }
    diag = s.title || '(no title)'
    await new Promise(r => setTimeout(r, 500))
  }
  if (!playerReady) throw new Error('player did not become ready (no <video>/#movie_player) after 60s — page title: "' + diag + '". If the video is gated, make sure a logged-in YouTube tab can play it; if YouTube is rate-limiting, wait and retry.')

  // Wait for metadata (duration>0) separately — up to 20s after the player exists.
  for (let i = 0; i < 40; i++) {
    const r = await cdp(sessionId, 'Runtime.evaluate', { expression: '(() => { const v = document.querySelector("video"); return v && v.duration > 0 ? v.duration : 0; })()', returnByValue: true })
    if (r.result.value && r.result.value > 0) break
    await new Promise(r => setTimeout(r, 500))
  }

  // Read title + available qualities (for --info and for the filename).
  const meta = await cdp(sessionId, 'Runtime.evaluate', {
    expression: '(() => { const p = document.querySelector("#movie_player"); const v = document.querySelector("video"); return JSON.stringify({ title: document.title || "", dur: v ? v.duration : 0, qualities: (p && p.getAvailableQualityLevels) ? p.getAvailableQualityLevels() : [] }); })()',
    returnByValue: true
  })
  const m = JSON.parse(meta.result.value)

  if (INFO_ONLY) {
    return JSON.stringify({ ok: true, info: true, title: m.title, duration: m.dur, qualities: m.qualities })
  }

  // Disable YouTube autonav BEFORE play so the player can never autoplay into
  // the next video. The toggle is .ytp-autonav-toggle; its state is in
  // aria-label/data-tooltip-title ("Autoplay is on" vs "... off"). Best-effort:
  // a missing or already-off toggle is a no-op. This is the real fix for the
  // background-tab case — even if the tab is throttled and the coverage poll
  // never latches, there is no next-video autoplay to run away to.
  await cdp(sessionId, 'Runtime.evaluate', {
    expression: '(() => { const b = document.querySelector(".ytp-autonav-toggle"); if (!b) return "no-toggle"; const lbl = (b.getAttribute("aria-label") || b.getAttribute("data-tooltip-title") || ""); if (/off/i.test(lbl)) return "already-off"; b.click(); return "clicked"; })()',
    returnByValue: true
  })

  // Force the requested quality (best-effort — SABR may ignore it) and play
  // muted at 16x so the player fetches+appends every segment fast. The model
  // is just "view it, sped up"; capture happens in the MSE hook as it plays.
  // Reset currentTime to 0: a signed-in account resumes from the last watch
  // position ("resume from where you left off") even on a bare watch?v=ID URL
  // with no t= — without this the capture only covers from the resume point on.
  await cdp(sessionId, 'Runtime.evaluate', {
    expression: '(() => { const p = document.querySelector("#movie_player"); const v = document.querySelector("video"); try { if (p && p.setPlaybackQualityRange) p.setPlaybackQualityRange("' + YTQ + '","' + YTQ + '"); if (p && p.setPlaybackQuality) p.setPlaybackQuality("' + YTQ + '"); } catch(e){} try { v.currentTime = 0; } catch(e){} v.muted = true; v.playbackRate = 16; v.play().catch(()=>{}); return "playing"; })()',
    returnByValue: true
  })

  // Wait until the whole timeline is buffered (the player buffers ahead), then
  // latch done. We break the FIRST time buffered.end >= dur-0.5 and never
  // re-check — so autoplay advancing to the next video (and resetting
  // currentTime) doesn't matter: we've already stopped. A deadline guards a
  // stalled stream. Each tick re-asserts muted + 16x: the player can clobber
  // them on a quality switch, ad, or player re-init, which would un-mute the
  // 16x chipmunk audio mid-capture.
  const dur = m.dur
  let last = -1
  const deadline = Date.now() + Math.max(60_000, dur * 1000 / 12 + 60_000)
  let done = false
  let tick = 0

  // --- Streaming drain helpers ---
  // drainFiles: buffer index -> { path, bytes, kind, ext }. One temp file per
  // captured SourceBuffer, appended as the hook records DURING playback. By
  // latch-time nearly all the media is already on disk, so the post-pause pull
  // is just the tail and the tab closes immediately at the latch signal — the
  // bytes live in page memory and the tab can't close until they're off, which
  // is why pulling everything after pause kept the tab open ~30s.
  // SLICE is SMALL: a single 4MB returnByValue frame closes the debug socket on
  // some browsers (proven on Dia), so each CDP response stays well under that.
  // (Divisible by 3 so each base64 slice is independently decodable.)
  const SLICE = 262143  // 256KB - 1, divisible by 3
  const extOf = (mime) => mime.includes('webm') ? 'webm' : 'fmp4'
  const drainFiles = new Map()
  // drainOne: pull every new byte of buffer i to its file since the last call.
  // __drainNew never emits more than SLICE even for a multi-MB fmp4 segment
  // (it slices a too-big chunk across drains), so this loop is socket-safe.
  const drainOne = async (i) => {
    for (;;) {
      const r = await cdp(sessionId, 'Runtime.evaluate', {
        expression: 'window.__drainNew(' + i + ',' + SLICE + ')',
        returnByValue: true
      })
      const s = r.result.value
      if (!s) return
      // __drainNew returns done:true WITH a non-empty b64 for the final slice
      // (it sets done when the cursor reaches the end on the same call that
      // yields the last bytes). Append BEFORE testing done, or that last slice
      // is silently dropped and the muxed file ends up truncated/corrupt.
      if (s.b64) {
        const chunk = Buffer.from(s.b64, 'base64')
        fs.appendFileSync(drainFiles.get(i).path, chunk)
        drainFiles.get(i).bytes += chunk.length
      }
      if (s.done) return
    }
  }
  // drainTick: discover all current buffers, open a file for each new one, and
  // drain them. Audio-only skips the (large) video stream.
  const drainTick = async () => {
    const infoR = await cdp(sessionId, 'Runtime.evaluate', { expression: 'JSON.stringify(window.__capInfo())', returnByValue: true })
    const buffers = JSON.parse(infoR.result.value)
    for (const b of buffers) {
      if (b.kind !== 'video' && b.kind !== 'audio') continue
      if (KEEP === 'audio' && b.kind === 'video') continue
      if (!drainFiles.has(b.i)) {
        const path = TMPDIR + '/' + b.kind + b.i + '.' + extOf(b.mime)
        fs.writeFileSync(path, Buffer.alloc(0))
        drainFiles.set(b.i, { i: b.i, path: path, bytes: 0, kind: b.kind, ext: extOf(b.mime) })
      }
      await drainOne(b.i)
    }
  }
  // --- end drain helpers ---

  for (;;) {
    if (Date.now() > deadline) { vlog('coverage timeout'); break }
    const r = await cdp(sessionId, 'Runtime.evaluate', {
      expression: '(() => { const v = document.querySelector("video"); if (v) { v.muted = true; v.playbackRate = 16; } return JSON.stringify({ t: v ? v.currentTime : 0, end: v && v.buffered.length ? v.buffered.end(v.buffered.length-1) : 0, ended: v ? v.ended : false }); })()',
      returnByValue: true
    })
    const s = JSON.parse(r.result.value)
    if (VERBOSE && Math.floor(s.t) !== Math.floor(last)) { last = Math.floor(s.t); vlog('t=' + s.t.toFixed(0) + '/' + dur.toFixed(0) + 's buffered=' + s.end.toFixed(0) + 's') }
    if (s.end >= dur - 0.5 || s.ended) { done = true; break }
    // Streaming drain during playback: flush whatever the hook has recorded so
    // far to disk. Runs ~every 1s (every 4th 250ms tick). By latch-time nearly
    // all the capture is on disk, so the post-pause pull is just the tail and
    // the tab closes immediately. __drainNew caps each CDP response at 256KB.
    if (++tick % 4 === 0) { try { await drainTick() } catch (e) { vlog('drain tick err: ' + (e?.message || e)) } }
    await new Promise(r => setTimeout(r, 250))
  }

  // Freeze capture + pause atomically. __capDone makes the hook pass appends
  // through (stop recording), so nothing the player does after this enters the
  // buffers — autoplay included.
  await cdp(sessionId, 'Runtime.evaluate', { expression: '(() => { window.__capDone = true; const v = document.querySelector("video"); if (v) v.pause(); return "frozen"; })()', returnByValue: true })
  vlog('coverage ' + (done ? 'complete' : 'timed out'))

  const infoR = await cdp(sessionId, 'Runtime.evaluate', { expression: 'JSON.stringify(window.__capInfo())', returnByValue: true })
  const buffers = JSON.parse(infoR.result.value)
  vlog('captured ' + buffers.length + ' source buffer(s): ' + JSON.stringify(buffers.map(b => b.kind + ':' + b.bytes)))

  // The player can create more than one MediaSource (quality-switch re-init,
  // mini-player, etc.), so there may be several video/audio drained files. Pick
  // the LARGEST of each kind — that is the real full capture; the small
  // init-segment duplicates get unlinked.
  let pv = null, pa = null
  for (const f of drainFiles.values()) {
    if (f.kind === 'video' && (!pv || f.bytes > pv.bytes)) pv = f
    if (f.kind === 'audio' && (!pa || f.bytes > pa.bytes)) pa = f
  }
  for (const f of drainFiles.values()) {
    if (f !== pv && f !== pa) { try { fs.unlinkSync(f.path) } catch {} }
  }

  // Final tail drain: __capDone is set, so no further appends can arrive — one
  // pass per chosen buffer pulls only what arrived since the last in-loop drain.
  // By now nearly all the capture is already on disk, so this is fast and the
  // tab closes right after the snippet returns.
  const drainTail = async (f) => { if (f) { try { await drainOne(f.i) } catch (e) { vlog('tail drain err: ' + (e?.message || e)) } } }
  await drainTail(pv); await drainTail(pa)

  const primary = {}
  if (KEEP === 'audio') {
    primary.audio = pa ? { path: pa.path, ext: pa.ext, bytes: pa.bytes } : null
  } else {
    primary.video = pv ? { path: pv.path, ext: pv.ext, bytes: pv.bytes } : null
    primary.audio = pa ? { path: pa.path, ext: pa.ext, bytes: pa.bytes } : null
  }

  // Best-effort read of the actual played quality.
  const qR = await cdp(sessionId, 'Runtime.evaluate', {
    expression: '(() => { const p = document.querySelector("#movie_player"); try { return (p && p.getPlaybackQuality) ? p.getPlaybackQuality() : ""; } catch(e){ return ""; } })()',
    returnByValue: true
  })

  return JSON.stringify({ ok: true, _stats: _stats, title: m.title, duration: dur, qualities: m.qualities, forcedQuality: YTQ, actualQuality: qR.result.value, videoPath: primary.video ? primary.video.path : null, videoExt: primary.video ? primary.video.ext : null, audioPath: primary.audio ? primary.audio.path : null, audioExt: primary.audio ? primary.audio.ext : null, tmpdir: TMPDIR })
} finally {
  // Fire-and-forget closeTab — guaranteed cleanup even on errors, without blocking.
  session.closeTab(t.targetId, sessionId).catch(() => {})
}
EOF
)

# The REPL returns a JSON string (or an error blob). Parse defensively —
# without jq, and without BSD-incompatible sed alternation.
case "$raw" in
  *'"ok":true'*) ;;
  *)
    echo "ytdl: capture failed:" >&2
    printf '%s\n' "$raw" >&2
    exit 1
    ;;
esac

# -v: print the in-snippet stats. (The REPL daemon's stderr isn't wired to this
# CLI, so the snippet collects stats and returns them in the JSON.)
if $verbose; then
  printf '%s\n' "$raw" | grep -oE '"_stats":\[[^]]*\]' | sed 's/"_stats":\[//; s/\]$//; s/,/\n/g' \
    | sed -e 's/^"//' -e 's/"$//' -e 's/^/ytdl: /' >&2 || true
fi

# --info path: print and exit.
if $info_only; then
  printf 'title:     %s\n' "$(printf '%s\n' "$raw" | grep -oE '"title":"[^"]*"' | head -1 | sed 's/"title":"//; s/"$//')"
  printf 'duration:  %ss\n' "$(printf '%s\n' "$raw" | grep -oE '"duration":[0-9.]+' | head -1 | sed 's/"duration"://')"
  printf 'qualities: %s\n' "$(printf '%s\n' "$raw" | grep -oE '"qualities":\[[^]]*\]' | head -1 | sed 's/"qualities"://')"
  exit 0
fi

# Derive the output name + container from the captured buffers.
title=$(printf '%s' "$raw" | sed -n 's/.*"title":"\([^"]*\)".*/\1/p' | head -1)
[ -n "$out" ] || out=$(printf '%s' "$title" | sed -e 's/^([^)]*)[[:space:]]*//' -e 's/ - YouTube$//' -e 's/[^A-Za-z0-9._-]/_/g')
[ -n "$out" ] || out="video"
mkdir -p "$dir"

# Extract the chosen temp files + container from flat fields the snippet returns
# (videoPath/videoExt/audioPath/audioExt). null -> no match -> empty. These
# fields carry no escaped quotes, so grep+sed is safe and brace-free.
video_path=$(printf '%s' "$raw" | sed -n 's/.*"videoPath":"\([^"]*\)".*/\1/p' | head -1)
video_ext=$(printf '%s' "$raw" | sed -n 's/.*"videoExt":"\([^"]*\)".*/\1/p' | head -1)
audio_path=$(printf '%s' "$raw" | sed -n 's/.*"audioPath":"\([^"]*\)".*/\1/p' | head -1)
audio_ext=$(printf '%s' "$raw" | sed -n 's/.*"audioExt":"\([^"]*\)".*/\1/p' | head -1)

if $verbose; then
  printf 'ytdl: video=%s audio=%s vext=%s aext=%s\n' "${video_path:-none}" "${audio_path:-none}" "${video_ext:-?}" "${audio_ext:-?}" >&2
fi

if [ "$keep" = "audio" ]; then
  # audio-only: keep the audio buffer in its own container.
  if [ -z "$audio_path" ]; then echo "ytdl: no audio buffer captured" >&2; exit 1; fi
  aout="m4a"; [ "$audio_ext" = "webm" ] && aout="webm"
  final="$dir/${out}.${aout}"
  cp "$audio_path" "$final"
  sz=$(wc -c < "$final" | tr -d ' ')
  echo "saved $final ($(( sz / 1024 )) KB, audio)"
  exit 0
fi

if [ -n "$video_path" ] && [ -n "$audio_path" ]; then
  ext="mp4"; [ "$video_ext" = "webm" ] && ext="webm"
  final="$dir/${out}.${ext}"
  if [ "$ext" = "webm" ]; then
    ffmpeg -hide_banner -y -loglevel error -i "$video_path" -i "$audio_path" -c copy "$final"
  else
    ffmpeg -hide_banner -y -loglevel error -i "$video_path" -i "$audio_path" -c copy -movflags +faststart "$final"
  fi
elif [ -n "$video_path" ]; then
  ext="mp4"; [ "$video_ext" = "webm" ] && ext="webm"
  final="$dir/${out}.${ext}"
  cp "$video_path" "$final"
elif [ -n "$audio_path" ]; then
  aout="m4a"; [ "$audio_ext" = "webm" ] && aout="webm"
  final="$dir/${out}.${aout}"
  cp "$audio_path" "$final"
else
  echo "ytdl: no media captured (is the video playable in a logged-in tab?)" >&2
  exit 1
fi

sz=$(wc -c < "$final" | tr -d ' ')
echo "saved $final ($(( sz / 1024 / 1024 )) MB)"
